# ============================================================================
# Reloaded Menswear — production .env template
#
# Copy to /opt/menswear/.env on the VPS, then fill in every REPLACE_*
# placeholder. After editing: chmod 600 .env
#
# Secrets generation cheatsheet:
#   openssl rand -base64 24   # POSTGRES_PASSWORD
#   openssl rand -base64 32   # any JWT_*_SECRET / TRACKING_TOKEN_SECRET / REVIEW_TOKEN_SECRET
# Use a DIFFERENT random string for each JWT secret — they're not interchangeable.
# ============================================================================

# ----------- Deployment metadata -----------
# Lowercase GitHub username/org used in the GHCR image path.
GITHUB_USER=your-github-username-lowercase
# `latest` follows the main branch; pin to a commit SHA for a known-good deploy.
IMAGE_TAG=latest

# ----------- Runtime -----------
NODE_ENV=production

# ----------- Database -----------
# Postgres lives on the internal `backend` docker network. The user/db names
# below match the postgres service environment in docker-compose.production.yml.
POSTGRES_PASSWORD=REPLACE_WITH_OPENSSL_RAND_BASE64_24
DATABASE_URL=postgresql://menswear:REPLACE_WITH_OPENSSL_RAND_BASE64_24@postgres:5432/menswear?schema=public

# ----------- Redis -----------
REDIS_URL=redis://redis:6379

# ============================================================================
# API (apps/api)
# ============================================================================
API_PORT=4000
API_HOST=0.0.0.0

# Admin auth — separate secrets per token type (access/refresh/stage).
JWT_ACCESS_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_OPENSSL_RAND_BASE64_32
JWT_STAGE_SECRET=REPLACE_WITH_THIRD_OPENSSL_RAND_BASE64_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_STAGE_TTL=5m

# Customer auth (Sprint 8) — distinct secrets so a stolen admin token can't be
# replayed as a customer token and vice versa.
JWT_CUSTOMER_ACCESS_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32
JWT_CUSTOMER_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_OPENSSL_RAND_BASE64_32
JWT_CUSTOMER_ACCESS_TTL=15m
JWT_CUSTOMER_REFRESH_TTL=30d

# OTP knobs (Sprint 8). Defaults are sensible; override only if needed.
CUSTOMER_OTP_TTL_MINUTES=10
CUSTOMER_OTP_MAX_ATTEMPTS=5
# Dev convenience — leave empty in production.
CUSTOMER_OTP_DEV_FALLBACK_EMAIL=

# HMAC secrets for tokenised public URLs (tracking link in confirmation
# email, review submission link in post-delivery email).
TRACKING_TOKEN_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32
REVIEW_TOKEN_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32

# Admin TOTP — keep on in production. Set to false only for an initial
# bring-up where you want to skip the 2FA enrolment for a single login.
ADMIN_TOTP_ISSUER=Reloaded Admin
ADMIN_TOTP_REQUIRED=true

# CORS — comma-separated allowlist for browser-facing endpoints.
CORS_ORIGINS=https://reloadedmens.in,https://www.reloadedmens.in,https://admin.reloadedmens.in

# Auth cookie Domain attribute. Must include a leading dot to allow the
# cookie to be sent across every subdomain. Without this the cookie minted
# by api.reloadedmens.in is host-only — client-side fetches from
# admin.reloadedmens.in and reloadedmens.in to the api would arrive without
# credentials and 401. Local dev leaves this unset (host-only on localhost).
COOKIE_DOMAIN=.reloadedmens.in

# ----------- File storage -----------
# Local-disk uploads under STORAGE_LOCAL_PATH inside the api container.
# docker-compose mounts a named volume so files survive image upgrades.
# PUBLIC_API_URL is the host the LocalStorageProvider stamps onto upload URLs;
# Caddy reverse-proxies api.reloadedmens.in to the api container.
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/data/storage
PUBLIC_API_URL=https://api.reloadedmens.in

# R2/S3 (Phase 2 — leave blank for now)
# STORAGE_DRIVER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# ----------- Payment provider — mock until Razorpay (+ Route) lands -----------
PAYMENT_PROVIDER=mock
MOCK_PAYMENT_AUTO_SUCCEED=true
MOCK_PAYMENT_DELAY_MS=2000
# HMAC secret the mock provider signs its self-fired webhook with.
MOCK_PAYMENT_WEBHOOK_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32

# Razorpay (Phase 2 — leave blank in MVP). Key id is public-safe (storefront
# loads it for the Checkout modal); key_secret + webhook_secret are server-only.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# Route — the linked-account id of the partner who takes a fixed % of every
# order, plus the split percent (default 5). Both also stored in the Settings
# table so admin can adjust at runtime without redeploy; env is the bootstrap.
# RAZORPAY_PARTNER_LINKED_ACCOUNT_ID=
# RAZORPAY_PARTNER_SPLIT_PERCENT=5

# ----------- Shipping provider — mock until Shiprocket lands -----------
SHIPPING_PROVIDER=mock
# Comma-separated `state:seconds` map to auto-progress mock shipments for
# demos. Leave empty for manual control via the admin.
MOCK_SHIPPING_AUTO_PROGRESS_TIMINGS=

# ----------- Email (Resend — leave blank until configured) -----------
RESEND_API_KEY=
EMAIL_FROM=orders@reloadedmens.in
EMAIL_FROM_NAME=Reloaded Menswear

# ----------- Observability (leave blank for now) -----------
SENTRY_DSN=

# ============================================================================
# Storefront — NEXT_PUBLIC vars are baked into the storefront bundle at build
# time on the GitHub Actions runner. Changing them requires a rebuild + push,
# not just a docker compose restart.
# ============================================================================
NEXT_PUBLIC_API_URL=https://api.reloadedmens.in
NEXT_PUBLIC_STOREFRONT_URL=https://reloadedmens.in
NEXT_PUBLIC_BRAND_NAME=Reloaded Mens
NEXT_PUBLIC_WHATSAPP_NUMBER=+919958247377

# ============================================================================
# Admin
# ============================================================================
NEXT_PUBLIC_ADMIN_API_URL=https://api.reloadedmens.in
NEXT_PUBLIC_ADMIN_URL=https://admin.reloadedmens.in

# ============================================================================
# Business info — read at seed time by packages/db/prisma/seed.ts and
# persisted to the Settings table. Surfaced in invoices, the footer, and the
# WhatsApp deep-link the storefront generates.
# ============================================================================
BUSINESS_NAME=Reloaded Menswear
BUSINESS_EMAIL=reloadedmens@gmail.com
BUSINESS_PHONE_PRIMARY=+919958247377
BUSINESS_PHONE_SECONDARY=+918285317062
BUSINESS_ADDRESS=L-285 Sector 23 Sanjay Nagar, Ghaziabad
BUSINESS_WHATSAPP=+919958247377
# GSTIN once registered; leave blank pre-registration.
BUSINESS_GSTIN=
