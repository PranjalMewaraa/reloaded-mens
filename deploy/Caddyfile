################################################################################
# Reloaded Menswear — production Caddyfile
#
# Posture: storefront is fully public. Admin + api have no basic_auth at the
# edge — admin enforces its own auth (JWT + RolesGuard) and the api does too
# (JWT cookies + CustomerAuthGuard / RolesGuard on every non-public route).
# X-Robots-Tag "noindex, nofollow" stays on admin + api so crawlers don't
# index those hostnames even though they're reachable.
#
# Cloudflare is in front of all three hostnames. Set Cloudflare SSL mode to
# "Full (strict)" once Caddy has issued its origin certs. Initial DNS records
# must be DNS-only (gray cloud) until first cert issuance — otherwise Caddy's
# HTTP-01 challenge gets eaten by Cloudflare's proxy.
################################################################################

{
	# Email used by Let's Encrypt for cert renewal warnings.
	email reloadedmens@gmail.com
}

# ----------------------------------------------------------------------------
# Storefront — public-facing, both apex and www aliases. Fully indexable.
# ----------------------------------------------------------------------------
reloadedmens.in, www.reloadedmens.in {
	encode gzip zstd

	header {
		# Long-life HSTS once SSL is stable. Subdomains included so
		# admin/api inherit on first visit.
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Drop the Server: caddy banner.
		-Server
	}

	reverse_proxy storefront:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}

	log {
		output file /data/access-storefront.log {
			roll_size 10MiB
			roll_keep 5
			roll_keep_for 720h
		}
		format console
	}
}

# ----------------------------------------------------------------------------
# Admin panel — no basic_auth; the admin app enforces its own JWT login.
# Kept noindex so crawlers don't list the login page.
# ----------------------------------------------------------------------------
admin.reloadedmens.in {
	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		# Admin never frames itself — DENY is stricter than SAMEORIGIN.
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Robots-Tag "noindex, nofollow"
		-Server
	}

	reverse_proxy admin:3001 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}

	log {
		output file /data/access-admin.log {
			roll_size 10MiB
			roll_keep 5
			roll_keep_for 720h
		}
		format console
	}
}

# ----------------------------------------------------------------------------
# API — NO basic_auth. The storefront's browser JS fetches this host
# cross-origin (NEXT_PUBLIC_API_URL); a basic_auth 401 here would also
# strip CORS headers and break every client-side call. The API enforces
# its own auth — public endpoints are public by design.
# ----------------------------------------------------------------------------
api.reloadedmens.in {
	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Robots-Tag "noindex, nofollow"
		-Server
	}

	reverse_proxy api:4000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}

	log {
		output file /data/access-api.log {
			roll_size 10MiB
			roll_keep 5
			roll_keep_for 720h
		}
		format console
	}
}
