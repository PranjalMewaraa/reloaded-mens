# =====================================================
# Shared / Database
# =====================================================
DATABASE_URL="postgresql://menswear:menswear_dev_password@localhost:5432/menswear?schema=public"
REDIS_URL="redis://localhost:6379"

# =====================================================
# API (apps/api)
# =====================================================
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development

# JWT secrets — generate with: openssl rand -base64 32
JWT_ACCESS_SECRET="change-me-in-production-access"
JWT_REFRESH_SECRET="change-me-in-production-refresh"
JWT_STAGE_SECRET="change-me-in-production-stage"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_STAGE_TTL=5m

# Admin auth display
ADMIN_TOTP_ISSUER="Menswear Admin"

# Set to false to bypass the TOTP step on /auth/login (MVP convenience).
# Defaults to true if unset — production MUST keep it true.
ADMIN_TOTP_REQUIRED=true

# CORS — comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# Object storage (local for MVP, R2/S3 later)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage
# Public URL prefix the API advertises for uploaded files. Used by LocalStorageProvider
# to build the public URL: `${PUBLIC_API_URL}/files/<key>`. ServeStatic mounts at /files.
PUBLIC_API_URL=http://localhost:4000
# STORAGE_DRIVER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# Payment provider (mock for MVP, phonepe later)
PAYMENT_PROVIDER=mock
MOCK_PAYMENT_AUTO_SUCCEED=true
MOCK_PAYMENT_DELAY_MS=2000

# PhonePe (Phase 2 — leave blank in MVP)
# PHONEPE_MERCHANT_ID=
# PHONEPE_SALT_KEY=
# PHONEPE_SALT_INDEX=1
# PHONEPE_ENV=sandbox
# PHONEPE_REDIRECT_URL=http://localhost:3000/checkout/callback

# Shipping provider (mock for MVP, shiprocket later)
SHIPPING_PROVIDER=mock

# Email (Resend — leave blank in MVP if not testing)
# RESEND_API_KEY=
EMAIL_FROM="orders@example.com"
EMAIL_FROM_NAME="Menswear Store"

# Sentry (optional)
# SENTRY_DSN=

# =====================================================
# Storefront (apps/storefront)
# =====================================================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME="Menswear Store"
NEXT_PUBLIC_WHATSAPP_NUMBER="+919999999999"

# =====================================================
# Admin (apps/admin)
# =====================================================
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:4000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
