{
  "extends": "@repo/config/tsconfig.node.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "declaration": false,
    // React Email templates live in src/email/templates/*.tsx and compile down to
    // React.createElement calls so @react-email/render can stringify them server-side.
    "jsx": "react",
    "esModuleInterop": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "**/*spec.ts"]
}
