// Prisma schema for the menswear ecommerce platform.
// Sprint 1 — admin auth + data foundations for catalog and inventory.
// More entities added incrementally per sprint. See architecture_plan.md.

generator client {
  provider      = "prisma-client-js"
  // `native` keeps local dev fast (matches the host's libssl).
  // `linux-musl-openssl-3.0.x` is the Alpine-based production runtime
  // (node:22-alpine) used by the Docker images on the VPS. Without it,
  // Prisma fails at startup with "Query engine library for current
  // platform not found".
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// Admin users — login to admin panel
// =====================================================
model AdminUser {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          String // 'admin' | 'staff'
  totpSecret    String?
  totpEnabledAt DateTime?
  lastLoginAt   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditEvents AuditEvent[]
  leads       Lead[]

  @@index([email])
}

// =====================================================
// Audit log for all admin actions
// =====================================================
model AuditEvent {
  id          String   @id @default(cuid())
  adminUserId String?
  eventType   String // 'admin.login.success', 'admin.totp.failure', 'product.create', etc.
  resource    String? // 'product:abc123', 'order:xyz789'
  payload     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([resource])
  @@index([createdAt])
}

// =====================================================
// Customers — auto-created on first order or OTP login
// =====================================================
model Customer {
  id                         String    @id @default(cuid())
  phone                      String    @unique // +91XXXXXXXXXX canonical
  name                       String?
  email                      String?
  defaultBillingAddressId    String?
  defaultShippingAddressId   String?
  totalOrders                Int       @default(0)
  totalRevenuePaisa          BigInt    @default(0)
  tags                       String[]  @default([])
  marketingConsentWhatsapp   Boolean   @default(false)
  marketingConsentWhatsappAt DateTime?
  marketingConsentSms        Boolean   @default(false)
  marketingConsentSmsAt      DateTime?
  marketingConsentEmail      Boolean   @default(false)
  marketingConsentEmailAt    DateTime?
  // Sprint 8 — bumped on every successful OTP login so refresh tokens issued
  // before that point are invalidated. Lets an admin "log out everywhere" in
  // Sprint 12 by bumping this field.
  sessionVersion             Int       @default(0)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  deletedAt                  DateTime?

  addresses Address[]
  orders    Order[]
  reviews   Review[]

  @@index([phone])
  @@index([email])
}

// =====================================================
// Addresses — billing/shipping, linked to customer
// =====================================================
model Address {
  id         String   @id @default(cuid())
  customerId String
  name       String
  phone      String // validated to +91XXXXXXXXXX at API boundary
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  country    String   @default("IN")
  type       String // 'billing' | 'shipping' | 'both'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([pincode])
}

// =====================================================
// Categories — self-referencing tree
// =====================================================
model Category {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  description    String?
  parentId       String?
  imageUrl       String?
  sortOrder      Int       @default(0)
  isActive       Boolean   @default(true)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  parent           Category?         @relation("Subcategories", fields: [parentId], references: [id], onDelete: SetNull)
  children         Category[]        @relation("Subcategories")
  productCategories ProductCategory[]

  @@index([slug])
  @@index([parentId])
  @@index([deletedAt])
}

// =====================================================
// Products — shared envelope around variants
// =====================================================
model Product {
  id                  String    @id @default(cuid())
  slug                String    @unique
  name                String
  description         String?
  hsnCode             String?
  // GST rate as whole percent (5, 12, 18, 28). Migrate to basis points if half-percents ever appear.
  gstRatePercent      Int?
  // 'online_shippable' | 'in_store_only' | 'both' — mirrors AVAILABILITY enum in @repo/types
  availabilityFlag    String    @default("online_shippable")
  basePricePaisa      Int
  compareAtPricePaisa Int? // MRP
  costPricePaisa      Int? // admin-only visibility
  isActive            Boolean   @default(true)
  isReturnable        Boolean   @default(true)
  // Array of { url, alt, sortOrder }
  images              Json      @default("[]")
  seoTitle            String?
  seoDescription      String?
  ogImageUrl          String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  variants          ProductVariant[]
  productCategories ProductCategory[]
  reviews           Review[]

  @@index([slug])
  @@index([isActive])
  @@index([deletedAt])
}

// =====================================================
// Product <-> Category join
// =====================================================
model ProductCategory {
  productId  String
  categoryId String
  sortOrder  Int    @default(0)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId, sortOrder])
}

// =====================================================
// Product variants — unit of inventory
// =====================================================
model ProductVariant {
  id                  String    @id @default(cuid())
  productId           String
  sku                 String    @unique
  size                String?
  color               String?
  priceOverridePaisa  Int? // null -> falls back to product basePricePaisa
  stockCount          Int       @default(0)
  reservedForExchange Int       @default(0)
  lowStockThreshold   Int       @default(3)
  barcode             String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  product              Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryEvents      InventoryEvent[]
  orderItems           OrderItem[]
  returnLines          ReturnLineItem[] @relation("ReturnedVariant")
  exchangeReservations ReturnLineItem[] @relation("ExchangeVariant")

  @@index([productId])
  @@index([sku])
  @@index([deletedAt])
}

// =====================================================
// Inventory audit log — every stock change writes a row
// =====================================================
model InventoryEvent {
  id           String   @id @default(cuid())
  variantId    String
  // 'store_sale' | 'online_order' | 'restock' | 'return_restock' | 'correction' | 'write_off'
  changeType   String
  delta        Int // signed
  stockBefore  Int
  stockAfter   Int
  actor        String // 'system' | 'customer' | 'staff' | 'admin'
  actorId      String?
  referenceId  String? // e.g. order id, return id
  note         String?
  createdAt    DateTime @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([variantId, createdAt])
  @@index([changeType])
}

// =====================================================
// Site-wide settings (key-value, admin-editable)
// =====================================================
model Setting {
  key       String   @id
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// =====================================================
// Orders (Sprint 4) — customer purchases. Items capture
// denormalised snapshots so historical orders stay correct
// when the catalog rows change underneath.
// =====================================================
model Order {
  id                      String    @id @default(cuid())
  orderNumber             String    @unique // 'RLD-000123'
  customerId              String?
  // Idempotency key sent by client on POST /public/orders. Repeat requests with the
  // same key return the existing order instead of double-creating.
  idempotencyKey          String    @unique
  // See ORDER_STATE in @repo/types. Sprint 4 uses only: 'payment_pending',
  // 'confirmed', 'payment_failed', 'cancelled'.
  state                   String    @default("payment_pending")
  // 'pending' | 'paid' | 'failed' | 'refunded' | 'partially_refunded'
  paymentState            String    @default("pending")
  subtotalPaisa           Int
  discountPaisa           Int       @default(0)
  shippingPaisa           Int       @default(0)
  taxPaisa                Int       @default(0)
  totalPaisa              Int
  appliedCouponCode       String?
  // Denormalised snapshots so live profile edits don't rewrite history.
  contactSnapshot         Json // { name, phone, email }
  shippingAddressSnapshot Json // { name, phone, line1, line2, city, state, pincode }
  customerNote            String?
  // Single staff-visible note. Edited inline on the admin detail page. Sprint 6+
  // can upgrade this to a per-comment thread if ops needs it.
  internalNote            String?
  etaDateFrom             DateTime?
  etaDateTo               DateTime?
  // Sprint 5 — lifecycle timestamps. Set as the order moves through the state machine.
  placedAt                DateTime  @default(now())
  confirmedAt             DateTime?
  packedAt                DateTime?
  shippedAt               DateTime?
  outForDeliveryAt        DateTime?
  deliveredAt             DateTime?
  cancelledAt             DateTime?
  cancelReason            String?
  // Carrier-side AWB / tracking id. Sprint 11 wires Shiprocket; Sprint 5 stores the
  // mock provider's fake 'MOCK-AWB-NNNNNN'.
  trackingNumber          String?
  // HMAC token derived from (orderId, phone, secret). Public tracking endpoints
  // require ?t=<token> matching this value. Stable for the order's lifetime.
  // Nullable for migration safety (Sprint 4 orders pre-date it) but new orders
  // always populate it — public-tracking enforces non-null at the service layer.
  trackingToken           String?   @unique
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  // Sprint 7 — promotion ids stamped at order placement. Immutable; admin order
  // detail looks up the named promotions for the totals card breakdown.
  appliedPromotionIds String[] @default([])

  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  payments       Payment[]
  events         OrderEvent[]
  refundRequests RefundRequest[]
  returnRequests ReturnRequest[]
  couponUsages   CouponUsage[]

  @@index([customerId])
  @@index([state])
  @@index([paymentState])
  @@index([createdAt])
  @@index([trackingNumber])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  variantId      String
  // Snapshot fields — frozen at order placement.
  productName    String
  variantLabel   String? // 'M · Black'
  sku            String
  hsnCode        String?
  gstRatePercent Int?
  quantity       Int
  unitPricePaisa Int // pre-tax, post any per-line discount
  discountPaisa  Int      @default(0)
  taxPaisa       Int      @default(0)
  totalPaisa     Int // quantity * unitPrice - discount + tax
  createdAt      DateTime @default(now())

  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant         ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Restrict)
  returnLineItems ReturnLineItem[]
  review          Review?

  @@index([orderId])
  @@index([variantId])
}

// =====================================================
// Promotion (Sprint 7) — merchandising rule. The condition+action JSON columns
// are validated by Zod discriminated unions in @repo/types on every write so
// the database stores only well-formed payloads.
// =====================================================
model Promotion {
  id            String    @id @default(cuid())
  name          String
  description   String?
  // When true, applies silently if conditions match and no coupon is entered.
  isAutomatic   Boolean   @default(false)
  isActive      Boolean   @default(true)
  // When false, this promotion cannot stack with any other (it wins alone if
  // selected). When true, the engine sorts by stackPriority ascending and
  // applies in order.
  stackable     Boolean   @default(false)
  stackPriority Int       @default(100)
  validFrom     DateTime?
  validTo       DateTime?
  // Array of { type: 'cart_subtotal_min' | ... , ...typed payload }. AND across entries.
  conditions    Json      @default("[]")
  // Array of { type: 'percent_off_order' | ... , ...typed payload }.
  actions       Json      @default("[]")
  usageCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  coupons Coupon[]

  @@index([isActive, isAutomatic])
  @@index([validFrom, validTo])
}

// =====================================================
// Coupon (Sprint 7) — redeemable code pointing to a Promotion. Many coupons
// can share one promotion (bulk influencer drops use batchLabel to group).
// =====================================================
model Coupon {
  id                    String   @id @default(cuid())
  code                  String   @unique // stored uppercase
  promotionId           String
  // 0 = unlimited. Hard cap on total redemptions.
  usageLimitTotal       Int      @default(0)
  // 0 = unlimited. Cap per customer (Customer.id if logged in; else phone).
  usageLimitPerCustomer Int      @default(1)
  usageCount            Int      @default(0)
  isActive              Boolean  @default(true)
  // Bulk-generated batches share this label so admins can filter/export per drop.
  batchLabel            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  promotion Promotion     @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  usages    CouponUsage[]

  @@index([promotionId])
  @@index([batchLabel])
}

// =====================================================
// CouponUsage (Sprint 7) — ledger row written when an order successfully
// redeems a coupon. customerId is preferred (Sprint 8 auth); until then `phone`
// is the per-customer dedupe key.
// =====================================================
model CouponUsage {
  id         String   @id @default(cuid())
  couponId   String
  customerId String?
  phone      String?
  orderId    String   @unique
  createdAt  DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId, customerId])
  @@index([couponId, phone])
}

// =====================================================
// Payments (Sprint 4) — one row per checkout attempt.
// Real PhonePe arrives in Sprint 10; the mock provider
// uses these rows now so the schema is forward-compatible.
// =====================================================
model Payment {
  id                String    @id @default(cuid())
  orderId           String
  // 'mock' | 'phonepe' (Phase 2)
  provider          String
  // Provider-side session id. Mock = local UUID; PhonePe = merchantTransactionId.
  providerSessionId String    @unique
  amountPaisa       Int
  // 'pending' | 'captured' | 'failed' | 'refunded'
  status            String    @default("pending")
  rawWebhook        Json?
  capturedAt        DateTime?
  failedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// =====================================================
// OrderEvent (Sprint 5) — append-only audit trail for the
// order timeline. Customer tracking + admin detail both
// render rows from here.
// =====================================================
model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  // ORDER_EVENT_TYPE in @repo/types — state transitions ('state.confirmed', etc.)
  // plus side channels ('payment.captured', 'payment.refunded', 'note.updated',
  // 'tracking.assigned').
  eventType String
  // Optional human-readable description rendered verbatim in timelines.
  message   String?
  // 'system' | 'customer' | 'staff' | 'admin'
  actor     String
  actorId   String?
  payload   Json?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([eventType])
}

// =====================================================
// RefundRequest (Sprint 5) — staff requests a refund,
// admin approves. Sprint 10 wires the real PhonePe refund
// API; today the mock provider just flips Payment.status.
// =====================================================
model RefundRequest {
  id             String    @id @default(cuid())
  refundNumber   String    @unique // 'RFD-000123'
  orderId        String
  // REFUND_STATUS in @repo/types:
  // 'pending_admin_approval' | 'approved' | 'rejected' | 'completed'
  status         String    @default("pending_admin_approval")
  amountPaisa    Int
  reason         String
  // AdminUser.id of staff/admin who filed the request. Kept as plain string (no FK)
  // so deactivating an admin doesn't cascade-delete the audit trail.
  requestedBy    String
  approvedBy     String?
  rejectedReason String?
  // PAYMENT_PROVIDER enum — set at approval time so we know which provider handled
  // the actual refund (mock now; phonepe in Sprint 10).
  provider       String?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  returnRequests ReturnRequest[]

  @@index([orderId])
  @@index([status])
}

// =====================================================
// ReturnRequest (Sprint 6) — customer-initiated returns/exchanges.
// Tied to a single Order but can span any subset of its OrderItems.
// =====================================================
model ReturnRequest {
  id                String    @id @default(cuid())
  returnNumber      String    @unique // 'RTN-000123'
  orderId           String
  // RETURN_STATE in @repo/types — Sprint 6 uses: 'requested', 'approved', 'rejected',
  // 'pickup_scheduled', 'store_dropoff_pending', 'in_transit', 'received',
  // 'verified', 'completed', 'cancelled'.
  state             String    @default("requested")
  // 'courier_pickup' | 'store_dropoff' (RETURN_METHOD in @repo/types)
  method            String
  customerNote      String?
  internalNote      String?
  rejectedReason    String?
  // Linked refund. Verification of any 'return' line auto-creates one and stamps
  // this — null when the request is exchange-only or replacement-only.
  refundRequestId   String?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  pickupScheduledAt DateTime?
  receivedAt        DateTime?
  verifiedAt        DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  order         Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items         ReturnLineItem[]
  refundRequest RefundRequest?   @relation(fields: [refundRequestId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([state])
  @@index([createdAt])
}

// =====================================================
// ReturnLineItem (Sprint 6) — one row per line of the original order being
// returned. Snapshot fields mirror OrderItem so historical returns stay intact.
// =====================================================
model ReturnLineItem {
  id                    String    @id @default(cuid())
  returnRequestId       String
  orderItemId           String
  variantId             String
  productName           String
  variantLabel          String?
  sku                   String
  unitPricePaisa        Int
  quantity              Int
  // RETURN_REASON enum: 'size_issue' | 'quality' | 'not_as_expected' | 'damaged' | 'other'
  reason                String
  reasonNote            String?
  // RETURN_TYPE enum: 'return' | 'exchange' | 'replacement'
  action                String
  exchangeVariantId     String?
  exchangeVariantLabel  String?
  // Set on admin verification — 'as_new' | 'used' | 'damaged'. Null until verified.
  verifiedCondition     String?
  // 'restock' | 'damage_writeoff' | 'pending' (default until verified).
  restockDecision       String    @default("pending")
  photoUrls             String[]  @default([])
  // Sprint 6 stamps the deadline; Sprint 17 cron scans it. ProductVariant.reservedForExchange
  // holds the actual count being held.
  exchangeReservedUntil DateTime?
  createdAt             DateTime  @default(now())

  returnRequest   ReturnRequest    @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem       OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  variant         ProductVariant   @relation("ReturnedVariant", fields: [variantId], references: [id], onDelete: Restrict)
  exchangeVariant ProductVariant?  @relation("ExchangeVariant", fields: [exchangeVariantId], references: [id], onDelete: SetNull)

  @@index([returnRequestId])
  @@index([variantId])
  @@index([exchangeVariantId])
}

// =====================================================
// CustomerOtp (Sprint 8) — pending email-OTP challenge for customer login.
// Not a FK to Customer so spam attempts don't create stub customer rows.
// =====================================================
model CustomerOtp {
  id          String    @id @default(cuid())
  phone       String
  codeHash    String
  // 'email' | 'sms' (Sprint 12+). Drives delivery routing + audit context.
  channel     String    @default("email")
  // Where we delivered the code. Email channel = the email address; SMS later.
  deliveredTo String
  attempts    Int       @default(0)
  expiresAt   DateTime
  consumedAt  DateTime?
  ipAddress   String?
  createdAt   DateTime  @default(now())

  @@index([phone, createdAt])
  @@index([expiresAt])
}

// =====================================================
// Lead (Sprint 8) — captured from /contact form or Meta Lead Ads (Sprint 11).
// =====================================================
model Lead {
  id               String    @id @default(cuid())
  // LEAD_SOURCE enum from @repo/types: 'meta_lead_ads' | 'whatsapp' | 'website_signup' | 'manual'.
  source           String
  // LEAD_STATUS enum: 'new' | 'contacted' | 'qualified' | 'converted' | 'lost'.
  status           String    @default("new")
  name             String?
  phone            String?
  email            String?
  message          String?
  // Meta-only fields. Populated by Sprint 11 webhook handler.
  metaFormId       String?
  metaLeadId       String?   @unique
  customFields     Json?
  assignedToId     String?
  internalNote     String?
  contactedAt      DateTime?
  convertedAt      DateTime?
  convertedOrderId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignedTo AdminUser? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([source])
  @@index([phone])
}

// =====================================================
// Review (Sprint 8) — text-only product reviews. One Review per OrderItem so
// the verified-buyer gate is structural. Photos arrive in Phase 2.
// =====================================================
model Review {
  id             String    @id @default(cuid())
  productId      String
  orderItemId    String    @unique
  customerId     String?
  // Snapshot fields survive customer deletion / phone changes.
  authorName     String
  rating         Int
  title          String
  body           String
  // REVIEW_STATUS in @repo/types: 'pending' | 'approved' | 'rejected'.
  status         String    @default("pending")
  rejectedReason String?
  approvedAt     DateTime?
  rejectedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  customer  Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([productId, status])
  @@index([status, createdAt])
}
